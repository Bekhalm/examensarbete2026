# Copy to .env and adjust. All values have sensible defaults.

# --- Server ---
PORT=3000
HOST=0.0.0.0
NODE_ENV=development
LOG_LEVEL=debug

# --- Polling / detection ---
DEFAULT_CHECK_INTERVAL_SEC=60
MIN_CHECK_INTERVAL_SEC=20
# Cap for exponential backoff after repeated failures (seconds).
MAX_BACKOFF_SEC=1800
SCHEDULER_TICK_MS=10000
MAX_CONCURRENCY=5
FETCH_TIMEOUT_MS=10000
COOLDOWN_MS=60000
MAX_ITEMS_PER_CHECK=40
SEEN_ITEMS_KEEP_PER_SOURCE=500
USER_AGENT=

# --- Security ---
# Block fetching private/loopback/link-local addresses (SSRF protection).
BLOCK_PRIVATE_NETWORK=true
# Comma-separated host:port allowed to bypass the private-network guard.
ALLOWED_HOSTS=
# Max manual /check calls per minute per IP.
CHECK_RATE_LIMIT_PER_MIN=30

# --- Notifications (all optional) ---
# Generic webhook (works with Slack/Discord/Teams incoming webhooks).
NOTIFY_WEBHOOK_URL=
# Email via SMTP, e.g. smtp://user:pass@smtp.example.com:587
SMTP_URL=
NOTIFY_EMAIL_FROM=
NOTIFY_EMAIL_TO=
# Web Push (VAPID). Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@example.com
